# ── Naagrik AI — Environment Variables ──
# Copy this file to .env and fill in your values

# Required: Gemini API key for AI chat
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Google Cloud API key (for Translation, TTS, Vision, NL APIs)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Optional: GCP project ID (for BigQuery analytics)
GOOGLE_CLOUD_PROJECT_ID=your_project_id

# Optional: BigQuery dataset name
BIGQUERY_DATASET=naagrik_analytics

# Optional: Server port (default 8080, set automatically by Cloud Run)
PORT=8080

# Optional: CORS origin lock for production
ALLOWED_ORIGIN=*

# Note: GEMINI_API_KEY and GOOGLE_CLOUD_API_KEY can be the same key
# if all APIs are enabled on the same GCP project.
